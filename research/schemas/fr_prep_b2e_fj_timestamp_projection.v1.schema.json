{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fr_prep_b2e_fj_timestamp_projection.v1.schema.json",
  "title": "FR-Prep-B2e FJ Timestamp Projection Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "checkpoint",
    "projection_version",
    "helper_path",
    "helper_fixture_deterministic_sha256",
    "accepted_formats",
    "accepted_format_ids",
    "canonical_output_format",
    "projected_field_paths",
    "timezone_policy",
    "fractional_second_policy",
    "whitespace_policy",
    "ambiguity_policy",
    "original_representation_excluded_from_identity",
    "audit_excluded_from_identity",
    "runtime_paths_excluded_from_identity",
    "frozen_evidence_modified",
    "real_data_access_allowed"
  ],
  "properties": {
    "schema_version": {
      "const": "fr_prep_b2e_fj_timestamp_projection.v1"
    },
    "checkpoint": {
      "const": "FR_PREP_B2E_R1A2"
    },
    "projection_version": {
      "const": "fj_timestamp_projection.v1"
    },
    "helper_path": {
      "const": "tools/fr_prep_b2e_fj_metadata_projection.py"
    },
    "helper_fixture_deterministic_sha256": {
      "const": "ff5f49dfa09d51a4734c70c2faa39181b89a20f23d93190e3889de8633246f10"
    },
    "accepted_formats": {
      "const": [
        "YYYY-MM-DDTHH:MM:SS",
        "YYYY-MM-DD HH:MM:SS",
        "YYYY.MM.DDTHH:MM:SS",
        "YYYY.MM.DD HH:MM:SS"
      ]
    },
    "accepted_format_ids": {
      "const": [
        "ISO_DATE_T",
        "ISO_DATE_SPACE",
        "MT5_DOTTED_DATE_T",
        "MT5_DOTTED_DATE_SPACE"
      ]
    },
    "canonical_output_format": {
      "const": "YYYY-MM-DDTHH:MM:SS"
    },
    "projected_field_paths": {
      "const": [
        "dataset_context.boundary_start_timestamp",
        "dataset_context.boundary_end_timestamp",
        "dataset_context.expected_timeline.first_timestamp",
        "dataset_context.expected_timeline.last_timestamp",
        "provenance.sources[*].first_timestamp",
        "provenance.sources[*].last_timestamp"
      ]
    },
    "timezone_policy": {
      "const": "NAIVE_ONLY_TIMEZONE_VALUES_REJECTED"
    },
    "fractional_second_policy": {
      "const": "REJECTED"
    },
    "whitespace_policy": {
      "const": "LEADING_TRAILING_REJECTED"
    },
    "ambiguity_policy": {
      "const": "EXACT_ALLOWLIST_NO_GUESSING"
    },
    "original_representation_excluded_from_identity": {
      "const": true
    },
    "audit_excluded_from_identity": {
      "const": true
    },
    "runtime_paths_excluded_from_identity": {
      "const": true
    },
    "frozen_evidence_modified": {
      "const": false
    },
    "real_data_access_allowed": {
      "const": false
    }
  }
}
